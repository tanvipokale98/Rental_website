<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
   
    <title>Document</title>
    <link rel="stylesheet" href="/css/cart.css">
</head>
<body>
    <nav id="navbar">
        <span class="logo">
        <img class="lg" src="/img_data/logo3.jpg" height="40" width="40" alt="Logo"/>
        <p class="lg">Cinematic Vision</p>
        </span>
        <div class="loca">
            <p class="text"><a href="/">Home</a></p>
            <p class="text"><a href="/category">Category</a></p>
            <p class="text"><a href="/about">About us</a></p>
            <p class="text"><a href="/cart">Cart</a></p>
            <p class="text"><a href="/user"><img src="/img_data/user.PNG" height="25px" width="25px"></a></p>
            <% if(found ==0){ %>
                <div class="text"><a href="/login"><button>Login</button></a></div>
           <% }else{ %>
                <div class="text"><a href="/logout"><button>Logout</button></a></div>
           <% } %>      
        </div>
    </nav>

<div class="main">
    <div class="cart">
        <div class="textc">Your Cart</div>
        <div class="box">
           <table>
            <thead><tr>
                
                <th>Product</th>
                <th>Rent</th>
                <th>Quantity</th>
                <th>Rental Days</th>
                <th>Total</th>
                <th>Action</th></tr>
            </thead>
            <tbody>
                <% for(let item of cart) { %>
                    <tr>
                        <td><%= item.name %></td>
                        <td><%= item.rent %></td>
                        <td>
                            <form method="post" action="/updatecart">
                                <input type="hidden" name="id" value="<%= item.id %>">
                                <input type="submit" value="-" name="dec" class="rem">
                                <input type="number" name="quantity" value="<%= item.quantity %>" readonly>
                                <input type="submit" value="+" name="inc" class="rem">
                            </form>
                        </td>
                        <td>
                            <form method="post" action="/rental">
                                <input type="hidden" name="id" value="<%= item.id %>">
                                <input type="submit" value="-" name="rdec" class="rem">
                                <input type="number" name="rental" value="<%= item.days %>" readonly>
                                <input type="submit" value="+" name="rinc" class="rem">
                            </form>
                        </td>
                        <td><%= item.rent * item.quantity* item.days %></td>
                        <td>
                            <form method="post" action="/removeprod">
                                <input type="hidden" name="id" value="<%= item.id %>">
                                <input type="submit" class="button" value="Remove" class="rem">
                            </form>
                        </td>
                    </tr>
                <% } %>
                
            </tbody>
            
             
            <tfoot>
                <td colspan="2"></td>
            <td>Total:</td>
            <td id="grandTotal"><%= total %></td>
                
            </tfoot>
           </table>
        </div>
        
        <form id="cartt" method="get" action="/placeorder">
        <input type="submit" class="form-group" value="Confirm Order & Pay" name="order">
    </form>
    </div>
    
</div>


</body>
</html>
