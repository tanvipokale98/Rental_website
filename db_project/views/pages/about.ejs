    <script>
      document.getElementById("require").addEventListener("submit", async function(event) {
          event.preventDefault(); // Prevent default form submission
      
          const feedbackText = document.getElementById("story").value;
      
          if (!feedbackText.trim()) {
              alert("Please enter feedback before submitting!");
              return;
          }
      
          try {
              const response = await fetch("/require", {
                  method: "POST",
                  headers: {
                      "Content-Type": "application/json"
                  },
                  body: JSON.stringify({ story: feedbackText })
              });
      
              const result = await response.json();
      
              if (result.success) {
                  alert("Feedback submitted successfully!");
                  window.location.href = "/about"; // Redirect to the about page
              } else {
                  alert("Error submitting feedback: " + result.message);
              }
          } catch (error) {
              console.error("Error:", error);
              alert("Something went wrong. Please try again.");
          }
      });
      </script>
